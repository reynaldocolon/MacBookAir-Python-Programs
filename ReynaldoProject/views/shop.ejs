<%- include('layout', { body: `
    <h1 style="color:white">Shop</h1>
    <div style="display:flex; gap:20px;">
        ${products.map(p => `
            <div class="card">
                <h3>${p.name}</h3>
                <p>${p.desc}</p>
                <button class="btn">Buy ${p.price}</button>
            </div>
        `).join('')}
    </div>
` }) %>