<%- include('layout', { body: `
    <div class="container">
        <div class="card">
            <h1 style="background: linear-gradient(to right, #1abc9c, #3498db); -webkit-background-clip: text; -webkit-text-fill-color: transparent; margin-bottom: 10px;">
                Get In Touch
            </h1>
            <p style="color: #94a3b8; margin-bottom: 30px;">
                Have a question or want to work together? Send me a message below.
            </p>

            <form action="/contact" method="POST" style="text-align: left;">
                <label style="display: block; margin-bottom: 5px; font-weight: 600; font-size: 0.9rem;">Full Name</label>
                <input name="name" placeholder="e.g. John Doe" required>

                <label style="display: block; margin: 15px 0 5px 0; font-weight: 600; font-size: 0.9rem;">Email Address</label>
                <input name="email" type="email" placeholder="name@company.com" required>

                <label style="display: block; margin: 15px 0 5px 0; font-weight: 600; font-size: 0.9rem;">Message</label>
                <textarea name="message" rows="5" placeholder="Tell me about your project..." required></textarea>

                <button type="submit" class="btn" style="margin-top: 20px;">Send Message</button>
            </form>
        </div>
    </div>
` }) %>


