<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reynaldo's Python Journey</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        /* This is a safety backup to keep it dark while the CSS loads */
        :root {
            --primary: #4ecca3;
            --bg: #0f172a;
        }
        body {
            background-color: var(--bg);
            color: #f8fafc;
            margin: 0;
            font-family: 'Inter', sans-serif;
        }
        .container {
            display: flex;
            flex-wrap: wrap;
            gap: 40px;
            max-width: 1200px;
            margin: 0 auto;
            padding: 80px 20px;
            align-items: center;
        }
        .card {
            background: #1e293b;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .btn {
            background: var(--primary);
            color: #0f172a;
            border: none;
            padding: 12px 25px;
            border-radius: 8px;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn:hover {
            transform: translateY(-2px);
            opacity: 0.9;
        }
    </style>
</head>
<body>

    <%- body %>

</body>
</html>
