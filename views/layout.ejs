<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reynaldo's Python Journey</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        :root { 
            --primary: #4ecca3; 
            --bg: #0f172a; 
            --card-bg: #1e293b;
        }
        body { 
            background-color: var(--bg); 
            color: #f8fafc; 
            margin: 0; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; 
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }
        
        /* Navbar / Menus */
        nav {
            background: var(--card-bg);
            padding: 1.5rem;
            display: flex;
            justify-content: center;
            gap: 2rem;
            border-bottom: 1px solid #334155;
        }
        nav a {
            color: #94a3b8;
            text-decoration: none;
            font-weight: 600;
            font-size: 1.1rem;
            transition: 0.3s;
        }
        nav a:hover { 
            color: var(--primary); 
        }

        /* Main Content Wrapper */
        .main-content {
            flex: 1;
        }

        /* Re-usable Classes */
        .container { max-width: 1200px; margin: 0 auto; padding: 40px 20px; }
        .btn { background: var(--primary); color: var(--bg); border: none; padding: 10px 20px; border-radius: 5px; cursor: pointer; font-weight: bold; }
    </style>
</head>
<body>

    <nav>
        <a href="/">Home</a>
        <a href="/shop">Shop</a>
        <a href="/contact">Contact</a>
        <a href="/admin">Admin</a>
    </nav>

    <div class="main-content">
        <%- body %>
    </div>

    <%- footer %>

</body>
</html>
