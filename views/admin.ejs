<%- include('layout', { body: `
    <div class="container" style="flex-direction: column; align-items: center;">
        
        <div class="card" style="margin-bottom: 40px;">
            <h2>Add New Product</h2>
            <form action="/admin/add-product" method="POST">
                <input name="name" placeholder="Item Name" required>
                <input name="price" placeholder="Price (e.g. $49.99)" required>
                <input name="image" placeholder="Image URL (or leave blank for placeholder)">
                <textarea name="description" placeholder="Short description..."></textarea>
                <button type="submit" class="btn">List Item</button>
            </form>
        </div>

        <div class="card">
            <h2>Customer Leads</h2>
            <table style="width: 100%; color: white; text-align: left;">
                <tr><th>Name</th><th>Email</th><th>Message</th></tr>
                ${leads.map(l => `<tr><td>${l.name}</td><td>${l.email}</td><td>${l.message}</td></tr>`).join('')}
            </table>
        </div>
    </div>
` }) %>